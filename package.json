{
  "name": "ai-diff-review",
  "version": "1.0.0",
  "description": "Trust scoring CLI for AI-generated code changes. Pipe git diff, get a 0-100 trust score.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ai-diff-review": "dist/cli.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format esm --dts --clean",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["ai", "code-review", "trust-score", "git-diff", "security", "cli", "ollama", "openai", "anthropic", "mcp"],
  "author": "yuga-hashimoto",
  "license": "MIT",
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
